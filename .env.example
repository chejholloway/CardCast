# Bluesky Card Cast - Environment Variables
# Copy this file to .env.local and fill in the values

# Node Environment
# Options: development, test, production
NODE_ENV=development

# Backend URL (public-facing)
# This is the URL where the Next.js backend is deployed
# For local development: http://localhost:3000
# For production: https://your-domain.vercel.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Bluesky Service URL
# The PDS (Personal Data Server) URL to connect to
# Defaults to https://bsky.social for production Bluesky
# Can be overridden for testing or private instances
BLUESKY_SERVICE_URL=https://bsky.social

# Extension Shared Secret
# REQUIRED: At least 16 characters
# This secret must be:
#   1. Generated securely (use: openssl rand -base64 32)
#   2. Shared between backend and extension build
#   3. Never committed to version control
# The extension includes this secret in every tRPC request header (x-extension-secret)
EXTENSION_SHARED_SECRET=your-secure-random-secret-min-16-chars

# Allowed Origin (Optional)
# Restrict CORS requests to a specific origin
# If not set, origin-based CORS is disabled
# Example: chrome-extension://your-extension-id
# Leave empty for local development
ALLOWED_ORIGIN=
