{
  "name": "bluesky-card-cast-ext",
  "version": "0.1.0",
  "private": true,
  "author": "Che' J. Holloway",
  "scripts": {
    "prepare": "husky",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true npm run build",
    "lint": "npx oxlint .",
    "lint:staged": "npx lint-staged",
    "dev:ext": "vite -c extension/vite.config.ts",
    "build:ext": "vite build -c vite.config.ts",
    "validate:ext": "node extension/scripts/validate-ext-build.js",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "docs": "typedoc --out docs/api",
    "docs:watch": "typedoc --out docs/api --watch",
    "ci-lite": "npm ci && npm run lint && npm run typecheck && npm run build:css && npm run build:ext"
  },
  "dependencies": {
    "@atproto/api": "^0.18.21",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "@upstash/ratelimit": "^2.0.8",
    "@vercel/kv": "^3.0.0",
    "cheerio": "^1.2.0",
    "dompurify": "^3.3.1",
    "framer-motion": "^12.34.3",
    "lodash-es": "^4.17.23",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.3.0",
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-react": "^7.22.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.10",
    "oxlint": "^1.49.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "puppeteer": "^24.37.5",
    "tailwindcss": "^4.2.0",
    "typedoc": "^0.0.4",
    "typedoc-plugin-markdown": "^4.4.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "oxlint --fix"
    ],
    "*.{json,md,css}": "prettier --write"
  }
}
