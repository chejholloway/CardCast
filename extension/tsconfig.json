{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "chrome",
      "vitest/globals",
      "vitest",
      "@testing-library/jest-dom",
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@server/*": ["../server/*"]
    }
  },
  "include": ["src"],
  "exclude": ["tests", "node_modules", "dist"]
}
