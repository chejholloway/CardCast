{
  "manifest_version": 3,
  "name": "Bluesky Link Card Composer",
  "description": "Enhances Bluesky with native-feeling rich link cards for sites whose OG metadata is not fetched by Bluesky.",
  "version": "0.1.0",
  "permissions": ["storage", "scripting", "activeTab", "tabs"],
  "host_permissions": ["https://bsky.app/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Bluesky Link Card"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/contentScript.tsx"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "minimum_chrome_version": "120"
}
